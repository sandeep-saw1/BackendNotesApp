<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NotesAPP</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body>
    <div class="w-full min-h-screen bg-zinc-900">
      
      <!-- Form Section -->
      <div class="p-3">
        <form action="/create" method="POST" class="space-y-3">
          <input
            type="text"
            name="title"
            placeholder="Title goes here..."
            required
            class="w-full bg-zinc-800 text-white placeholder-zinc-500 px-4 py-3 rounded border border-zinc-700 outline-none"
          />

          <textarea
            name="content"
            rows="3"
            placeholder="Write your task details here..."
            required
            class="w-full bg-zinc-800 text-white placeholder-zinc-500 px-4 py-3 rounded border border-zinc-700 resize-none outline-none"
          ></textarea>

          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded cursor-pointer"
          >
            Create Task
          </button>
        </form>
      </div>

      <!-- Tasks Section -->
      <div class="tasks p-6">

        <% if(files.length > 0) { %>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

            <% files.forEach(function(val) { %>

              <div class="bg-zinc-800 p-5 rounded-lg shadow-lg">
                <h2 class="text-xl font-semibold text-white mb-2">
                  <%= val %>
                </h2>

              <a
                 href="/files/<%= val.replace('.txt', '') %>"
                 class="text-blue-500 hover:text-blue-400"
                 >
               Read More →
              </a>
              </div>

            <% }) %>

          </div>

        <% } else { %>

          <h1 class="text-2xl font-bold text-white">
            No tasks yet...
          </h1>

        <% } %>

      </div>

    </div>
  </body>
</html>
