<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NotesAPP</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">

      <a
        href="/"
        class="inline-block text-blue-500 hover:text-blue-400 mb-8"
      >
        ← Go Back to Home
      </a>

      <div class="bg-zinc-800 rounded-xl p-8 shadow-lg">
        <h1 class="text-4xl font-bold mb-4">
          <%= filename %>
        </h1>

        <p class="text-zinc-300 text-lg leading-relaxed">
          <%= filedata %>
        </p>
      </div>

    </div>
  </body>
</html>